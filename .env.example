# ===== Application =====
APP_NAME=academic-figure-generator
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
API_V1_PREFIX=/api/v1

# ===== Database =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=afg_user
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=academic_figure_generator
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# ===== MinIO =====
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_BUCKET_NAME=academic-figures
MINIO_USE_SSL=false

# ===== JWT =====
JWT_SECRET_KEY=${SECRET_KEY}
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Encryption (for BYOK API keys) =====
ENCRYPTION_MASTER_KEY=change-me-to-a-32-byte-hex-key

# ===== Prompt AI（平台默认文本模型）=====
# anthropic | openai-compatible
PROMPT_AI_PROVIDER=anthropic
PROMPT_AI_API_KEY=sk-ant-xxxx
PROMPT_AI_API_BASE_URL=
PROMPT_AI_MODEL=claude-sonnet-4-20250514
PROMPT_AI_MAX_TOKENS=8192

# ===== NanoBanana API (Platform Key) =====
NANOBANANA_API_KEY=your-nanobanana-api-key
NANOBANANA_API_BASE=https://api.keepgo.icu
NANOBANANA_MODEL=gemini-3-pro-image-preview

# ===== CORS =====
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ===== Rate Limiting =====
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_GENERATION=20/hour

# ===== File Upload =====
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain
